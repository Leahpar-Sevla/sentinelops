# SentinelOps - Phase 3 Heartbeat Runner
# Check: SENTINELOPS-[CLIENTE]-[HOSTNAME]-HEARTBEAT
# Schedule: every 1 hour
# Healthchecks: Period 1 hour, Grace Time 15 minutes

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

5 * * * * root /opt/sentinelops/bin/sentinelops-heartbeat-runner.sh >> /var/log/sentinelops/heartbeat-cron.log 2>&1
